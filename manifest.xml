<package version="0.0">
  <name>org.openxtalk.nstoolbar</name>
  <title>NSToolbar Library</title>
  <author>Emily-Elizabeth Howard</author>
  <version>1.0.0</version>
  <license>community</license>
  <type>library</type>
  <requires name="com.livecode.foreign"/>
  <requires name="com.livecode.engine"/>
  <requires name="com.livecode.string"/>
  <requires name="com.livecode.arithmetic"/>
  <requires name="com.livecode.binary"/>
  <requires name="com.livecode.list"/>
  <requires name="com.livecode.logic"/>
  <requires name="com.livecode.type"/>
  <requires name="com.livecode.system"/>
  <requires name="com.livecode.array"/>
  <metadata key="platform">mac</metadata>
  <handler name="toolbarCreate" parameters="in integer,in string,in string" return="nothing"/>
  <handler name="toolbarAddItem" parameters="in string,in string,in string,in string" return="nothing"/>
  <handler name="toolbarReloadItems" parameters="" return="nothing"/>
  <handler name="toolbarRemoveItem" parameters="in string" return="nothing"/>
  <handler name="toolbarSetItemEnabled" parameters="in string,in boolean" return="nothing"/>
  <handler name="toolbarSetCustomizable" parameters="in boolean" return="nothing"/>
  <handler name="toolbarSetVisible" parameters="in boolean" return="nothing"/>
  <handler name="toolbarIsVisible" parameters="" return="boolean"/>
  <handler name="toolbarItemIsEnabled" parameters="in string" return="boolean"/>
  <handler name="toolbarDestroy" parameters="" return="nothing"/>
</package>